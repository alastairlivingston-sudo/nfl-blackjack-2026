{
  "name": "nfl-blackjack-2026",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "tsx lib/db/migrate.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "import:players": "tsx scripts/import-players.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- tsx lib/db/migrate.ts",
    "db:seed-players": "dotenv -e .env.local -- tsx scripts/seed-players.ts",
    "test": "tsx --test \"lib/**/*.test.ts\"",
    "stats:ingest": "dotenv -e .env.local -- tsx scripts/ingest-stats.ts",
    "leaderboard:compute": "dotenv -e .env.local -- tsx scripts/compute-leaderboard.ts",
    "backfill:play-team": "dotenv -e .env.local -- tsx scripts/backfill-play-team.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@neondatabase/serverless": "^1.1.0",
    "canvas-confetti": "^1.9.4",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.14.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
