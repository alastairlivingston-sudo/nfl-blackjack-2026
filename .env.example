# Neon Postgres connection string (Vercel Postgres / Neon).
# Get it from the Vercel project's Storage tab, or neon.tech directly.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>`.
# Vercel sets this automatically for cron-triggered requests if you set the
# same value as a project env var — generate any random string.
CRON_SECRET=

# NFL season the app is scoring. Defaults to the current calendar year.
NFL_SEASON=2026

# Week 1 kickoff (ISO timestamp). Before this, the public scoreboard hides
# totals/picks/ranks (entrants only show as "Entered"); at/after this, it's
# locked and the full reveal goes live. Unset = treated as not-yet-locked.
LOCK_AT=2026-09-10T00:15:00Z

# Auth.js (NextAuth v5) session secret — generate with `npx auth secret`.
AUTH_SECRET=

# Google OAuth ("Continue with Google") — the only sign-in method. Create an
# OAuth client at https://console.cloud.google.com/apis/credentials
# (type: Web application). Authorized redirect URI:
#   https://YOUR_DOMAIN/api/auth/callback/google   (prod)
#   http://localhost:3000/api/auth/callback/google  (local dev)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend API key, used only for the optional feedback-digest / cron-alert
# emails (not auth — sign-in is Google OAuth).
AUTH_RESEND_KEY=

# Sender address for the feedback-digest / cron-alert emails.
AUTH_EMAIL_FROM="Touchdown Blackjack <no-reply@touchdownblackjack26.app>"

# Comma-separated allowlist of emails granted access to /admin.
ADMIN_EMAILS=

# Outbound JustGiving link shown in the footer CTA. Unset = CTA hidden.
JUSTGIVING_URL=

# Inbox that receives the feedback digest email. Unset = feedback is still
# saved to the `feedback` table, just not emailed.
FEEDBACK_NOTIFY_EMAIL=
