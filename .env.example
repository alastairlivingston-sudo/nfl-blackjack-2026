# Neon Postgres connection string (Vercel Postgres / Neon).
# Get it from the Vercel project's Storage tab, or neon.tech directly.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>`.
# Vercel sets this automatically for cron-triggered requests if you set the
# same value as a project env var — generate any random string.
CRON_SECRET=

# NFL season the app is scoring. Defaults to the current calendar year.
NFL_SEASON=2026
